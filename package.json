{
  "name": "hypercinema",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "guard:no-wallet-connect": "node scripts/guard-no-wallet-connect.mjs",
    "lint": "npm run guard:no-wallet-connect && eslint",
    "test": "npm run guard:no-wallet-connect && vitest run",
    "test:live": "npm run guard:no-wallet-connect && vitest run tests/live.external-smoke.test.ts",
    "test:watch": "npm run guard:no-wallet-connect && vitest",
    "test:ci": "npm run guard:no-wallet-connect && vitest run --reporter=default",
    "video:dev": "tsx video-service/src/server.ts",
    "video:build": "tsc -p video-service/tsconfig.json",
    "video:start": "node video-service/dist/server.js"
  },
  "dependencies": {
    "@dexterai/x402": "^2.0.0",
    "@google-cloud/storage": "^7.17.3",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@solana/web3.js": "^1.98.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "fastify": "^5.6.2",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.5.0",
    "helius-sdk": "^2.2.2",
    "next": "16.1.6",
    "node-telegram-bot-api": "^0.67.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "xai-sdk": "^1.0.0-alpha.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "utf-8-validate": "^5.0.10"
  }
}
