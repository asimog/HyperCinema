# ===========================================================
# HyperCinema — Railway Environment Variables
# ===========================================================
# Copy this file to Railway's Variables page for each service.
#
# SERVICE SHARING: All services (worker, video) share the same
# variables. Railway lets you copy variables between services.
# Set them once on one service, then copy to the others.
#
# The frontend runs on Vercel and has its own env vars.
#
# REQUIRED variables are marked [REQUIRED].
# ===========================================================

# -----------------------------------------------------------
# BLOCK 1: DATABASE [REQUIRED]
# -----------------------------------------------------------
# Railway provides a managed PostgreSQL database.
# Add a PostgreSQL service in Railway and use the generated
# DATABASE_URL (internal connection string).

[REQUIRED] DATABASE_URL=postgresql://user:password@db.railway.internal:5432/hypercinema

# -----------------------------------------------------------
# BLOCK 2: xAI — Video Generation [REQUIRED]
# -----------------------------------------------------------
# Get your API key from: https://console.x.ai/

[REQUIRED] XAI_API_KEY=xai-your-api-key-here
[REQUIRED] XAI_VIDEO_MODEL=grok-imagine-video
XAI_BASE_URL=https://api.x.ai/v1

# -----------------------------------------------------------
# BLOCK 3: X (Twitter) API — Tweet Scraping & Posting [REQUIRED for social features]
# -----------------------------------------------------------
# Get these from: https://developer.x.com/

[REQUIRED] X_API_BEARER_TOKEN=your-bearer-token-here

# OAuth 1.0a keys (needed only if posting tweets)
X_API_CONSUMER_KEY=
X_API_CONSUMER_SECRET=
X_API_ACCESS_TOKEN=
X_API_ACCESS_TOKEN_SECRET=

# -----------------------------------------------------------
# BLOCK 4: TELEGRAM BOT (optional)
# -----------------------------------------------------------
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------
# BLOCK 5: APP CONFIGURATION
# -----------------------------------------------------------

# Public URL of the Vercel frontend
APP_BASE_URL=https://your-app.vercel.app

# URL of the video service (Railway internal DNS)
# e.g. http://video.railway.internal:8090
VIDEO_API_BASE_URL=http://video.railway.internal:8090

# Auth key for video service API calls
VIDEO_API_KEY=generate-a-random-secret-key-here

# Admin cockpit credentials
COCKPIT_USERNAME=admin
COCKPIT_PASSWORD=your-secure-password

# -----------------------------------------------------------
# BLOCK 6: FALLBACK PROVIDERS (optional)
# -----------------------------------------------------------

# OpenRouter — fallback text provider
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# MythX — fallback video provider
MYTHX_API_KEY=
MYTHX_BASE_URL=https://cloud.milady.ai

# OpenMontage — local video rendering (auto-installed in Docker)
OPENMONTAGE_PATH=/app/openmontage
OPENMONTAGE_OUTPUT=/app/openmontage/output

# -----------------------------------------------------------
# BLOCK 7: MEDIA STORAGE
# -----------------------------------------------------------

# For Railway: use local filesystem with a Persistent Volume
MEDIA_BACKEND=local
MEDIA_LOCAL_ROOT=/app/data/media
