# ===========================================================
# HyperCinema — Railway Environment Variables
# ===========================================================
# Copy these variables to each Railway service.
# Worker and video-service share the same variable set.
# Frontend runs on Vercel with its own env vars.
#
# [REQUIRED] = must be set before deploy
# ===========================================================

# -----------------------------------------------------------
# DATABASE
# -----------------------------------------------------------
# Use Railway's managed PostgreSQL service.
# Copy the internal connection string from the DB service.
[REQUIRED] DATABASE_URL=postgresql://user:password@db.railway.internal:5432/hypercinema

# -----------------------------------------------------------
# xAI — Video Generation + Text Inference
# -----------------------------------------------------------
# Get your API key from: https://console.x.ai/

[REQUIRED] XAI_API_KEY=xai-your-api-key-here
XAI_BASE_URL=https://api.x.ai/v1
XAI_VIDEO_MODEL=grok-imagine-video

# -----------------------------------------------------------
# VIDEO SERVICE
# -----------------------------------------------------------
# Internal Railway URL for worker → video-service calls
[REQUIRED] VIDEO_API_BASE_URL=http://video.railway.internal:8090

# Shared secret — must match on both worker and video-service
[REQUIRED] VIDEO_API_KEY=generate-a-random-secret-here

# Public HTTPS URL of the video service (used in status URLs)
# Find this in Railway → video service → Settings → Domains
VIDEO_SERVICE_BASE_URL=https://your-video-service.railway.app

# -----------------------------------------------------------
# STORAGE — Supabase S3
# -----------------------------------------------------------
# Create a "videos" bucket in Supabase Storage (public).
# Get keys from: Supabase → Settings → Storage → S3 Access

[REQUIRED] S3_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
[REQUIRED] S3_ACCESS_KEY_ID=your-supabase-s3-access-key-id
[REQUIRED] S3_SECRET_ACCESS_KEY=your-supabase-s3-secret-key
S3_BUCKET=videos
S3_REGION=us-east-1
# Public CDN base — auto-detected from S3_ENDPOINT if not set
# S3_PUBLIC_URL=https://your-project-ref.supabase.co/storage/v1/object/public/videos

# -----------------------------------------------------------
# X (TWITTER) API — Tweet scraping + social posting
# -----------------------------------------------------------
# Get from: https://developer.x.com/

[REQUIRED] X_API_BEARER_TOKEN=your-bearer-token-here

# OAuth 1.0a — only needed if posting tweets
X_API_CONSUMER_KEY=
X_API_CONSUMER_SECRET=
X_API_ACCESS_TOKEN=
X_API_ACCESS_TOKEN_SECRET=

# -----------------------------------------------------------
# TELEGRAM BOT (optional)
# -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------
# Public URL of your Vercel frontend
APP_BASE_URL=https://your-app.vercel.app

# Admin cockpit credentials
COCKPIT_USERNAME=admin
COCKPIT_PASSWORD=change-me

# Worker auth token — called by Vercel to trigger jobs
[REQUIRED] WORKER_TOKEN=generate-a-random-secret-here

# -----------------------------------------------------------
# SOLANA / HELIUS (optional — for wallet recap jobs)
# -----------------------------------------------------------
HELIUS_API_KEY=
