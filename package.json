    "fastify": "^5.6.2",
    "next": "16.1.6",
    "node-telegram-bot-api": "^0.67.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.3",
